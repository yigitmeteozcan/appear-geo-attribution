# appear server — copy this file to .env and fill in your values

# Required: API key for authenticating requests to /appear/stats
# Generate with: openssl rand -hex 32
API_KEY=your_secret_api_key_here

# Stripe integration
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# LemonSqueezy integration
LEMONSQUEEZY_WEBHOOK_SECRET=...

# Comma-separated list of allowed CORS origins
# The browser snippet's host page domain must be listed here
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Port to listen on (default: 3000)
PORT=3000

# Optional: path to SQLite database file for persistent storage
# Comment out or leave unset to use in-memory store only
# DATABASE_URL=./appear.db
